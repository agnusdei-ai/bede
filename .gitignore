# Secrets — never commit these
.env
.env.backup
.env.local

# Local Postgres backups (make db-backup) — never commit these
/backups/

# scripts/build_pages_site.sh's assembled Cloudflare Pages output —
# regenerated on every build, never committed (see docs/DEMO_HOSTING.md)
/publish/

# Generated per-deployment — embeds this deployment's real CA cert
sage-root-ca.crt
bede-ipad.mobileconfig

# Claude Code agent worktrees (ephemeral, not source)
.claude/

#Config files or byte-compiled / optimized / DLL files
/config.py
__pycache__/
*.py[cod]
*$py.class

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py


# PyCharm
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/
