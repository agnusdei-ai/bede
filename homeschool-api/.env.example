# Copy this to .env and fill in every REPLACE_ME before running.
# The root .env.example has full documentation — this file is for running
# the API server standalone (outside Docker).

ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ── Provider adapters (which LLM vendor backs the tutor) ─────────────────────
# Bede talks to a provider ADAPTER, not a hardcoded Anthropic client, so it
# survives losing access to any single vendor. See docs/PROVIDER_ADAPTERS.md.
#
# BEDE_ADAPTER_ORDER is a comma-separated preference list; the first adapter
# that is actually configured wins. The DEFAULT is "local,anthropic" — the
# refactor exists for the case where Anthropic access is gone, so a self-hosted
# vLLM server (local) is the practical primary and Anthropic is only an optional
# fallback. You do NOT need ANTHROPIC_API_KEY set for Bede to boot or serve.
# BEDE_ADAPTER_ORDER=local,anthropic
# Pin to exactly one provider (skips order/failover). Leave empty normally.
# BEDE_FORCE_ADAPTER=local
#
# Local self-hosted LLM (any OpenAI-compatible server, e.g. vLLM serving
# Qwen/Qwen3-Coder-30B-A3B-Instruct with --tool-call-parser qwen3_coder).
# This model needs a GPU and CANNOT run inside the Render web service (Render
# has no GPU instances). Run vLLM on separate GPU hardware and point this at its
# /v1 endpoint over the network. Empty = the local adapter is skipped.
# LOCAL_LLM_BASE_URL=http://your-gpu-box.lan:8000/v1
# LOCAL_LLM_API_KEY=not-needed
# LOCAL_LLM_MODEL=Qwen/Qwen3-Coder-30B-A3B-Instruct
#
# OpenAI as a chat SECONDARY (distinct from OpenAI TTS below — it reuses the
# same OPENAI_API_KEY). Only used for tutoring if you add "openai" to
# BEDE_ADAPTER_ORDER, e.g. BEDE_ADAPTER_ORDER=local,openai,anthropic.
# OPENAI_MODEL=gpt-4.1-mini
#
# Mistral as an optional chat secondary (add "mistral" to BEDE_ADAPTER_ORDER).
# MISTRAL_API_KEY=REPLACE_ME
# MISTRAL_MODEL=mistral-large-latest

# Optional: run this deployment in a language other than English. Bede
# converses with the student natively in that language (not machine
# translation); the frontend needs its own matching VITE_LOCALE build-time
# var to translate the UI chrome. One locale per deployment, not a runtime
# switcher — see docs/LOCALIZATION.md for what's supported and what's not.
# LOCALE=es

# Optional: Bede's spoken voice via OpenAI's TTS API — meaningfully more
# natural than the browser's default speechSynthesis. Leave unset to skip
# cloud voice entirely; the browser's own speech takes over automatically.
# See docs/VOICE_SETUP.md.
# OPENAI_API_KEY=sk-REPLACE_ME
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OPENAI_TTS_VOICE=fable
# OPENAI_TTS_INSTRUCTIONS=Speak as an elderly, warm, unhurried Southern English monk.

# Optional: lets a parent (or demo visitor) get Bede's end-of-session notes
# emailed to them via Resend (https://resend.com). The address is used for
# exactly one send and is never written to the database or audit log — see
# services/email_service.py. Leave RESEND_API_KEY unset to disable entirely.
# RESEND_FROM_ADDRESS must be a sender verified against a domain you've added
# and verified in your Resend account (Resend rejects sends otherwise).
# RESEND_API_KEY=re_REPLACE_ME
# RESEND_FROM_ADDRESS=Bede <bede@yourdomain.com>

# Optional: urgent parent notification when Bede detects a child in distress
# or danger (services/ai_service.py's check_safeguarding) — reuses the same
# Resend setup above. Unlike the diagnostic email, this is child-triggered,
# so it needs an address configured ahead of time rather than typed in at
# send time. The safeguarding event is always written to the encrypted audit
# log regardless of whether this is set — this just adds a real-time alert
# on top of that passive record. Leave unset to disable this specific alert.
# PARENT_EMAIL=parent@example.com

SECRET_KEY=generate-with-openssl-rand-hex-32
MASTER_SECRET=generate-with-openssl-rand-hex-32

PARENT_PASSWORD=REPLACE_ME
# 6+ digits, no digit repeated (e.g. 384756, not 111111 or 123123)
CHILD_PIN=REPLACE_ME

# Optional: only for a dedicated PUBLIC DEMO deployment, never a family's real
# instance. Leave blank to disable the demo entirely (default). If set, must
# differ from both PARENT_PASSWORD and CHILD_PIN — startup fails otherwise.
# Not a credential anyone types — purely the on/off switch for the demo;
# visitors log in via a self-service one-time code (POST /auth/demo-code)
# instead, which can only reach a fixed, read-mostly tutoring session
# (services/ai_service.py + core/deps.py's require_real_user) — no
# pod/voice/admin/transcript access, no configuration rights.
# DEMO_PIN=
# DEMO_CODE_TOKEN_EXPIRE_MINUTES=120
# DEMO_STUDENT_NAME=Guest
# DEMO_GRADE=4
# DEMO_GRADE_STAGE=3-5

# Optional: per-IP rate limits, in requests per minute per client IP. The
# defaults (auth 10, api 120, voice 20, voice_stream_session 120) suit a
# family LAN and ordinary public-demo traffic. Raise them for an event where
# many visitors share one public IP (a conference room's Wi-Fi looks like a
# single very chatty client to a per-IP limiter). Takes effect on restart.
# RATE_LIMIT_AUTH_PER_MINUTE=10
# RATE_LIMIT_API_PER_MINUTE=120
# RATE_LIMIT_VOICE_PER_MINUTE=20
# voice_stream_session covers the mechanics of an already-started streaming-
# transcription session (chunk uploads, finish, the SSE event stream) — see
# docs/VOICE_SETUP.md's rate-limit regression section. RATE_LIMIT_VOICE_PER_MINUTE
# above is the stricter budget for actual new session starts.
# RATE_LIMIT_VOICE_STREAM_SESSION_PER_MINUTE=120

# Optional: unlocks a direct-answer "sandbox" chat for testing/exploring how
# Bede responds — no Socratic-only rule, free topic-switching, nothing ever
# persisted (no DB writes at all). Not a separate login/role: it rides on an
# already-authenticated parent session (core/deps.py's require_parent) plus
# this PIN checked on every request. Leave blank to disable entirely
# (default). Same strength rules as CHILD_PIN/DEMO_PIN, and must differ from
# all of PARENT_PASSWORD, CHILD_PIN, and DEMO_PIN — startup fails otherwise.
# SANDBOX_PIN=

# Optional: parent-side MFA (FIDO2 security key like a YubiKey, and/or a TOTP
# authenticator app) on top of PARENT_PASSWORD. Leave WEBAUTHN_RP_ID blank to
# disable security-key support (default) — TOTP has no such requirement and
# is always available once a parent enrolls it from the setup screen.
# WEBAUTHN_RP_ID must be the exact domain (no scheme/port) tablets/browsers
# use to reach this deployment, e.g. bede.local — WebAuthn will refuse to
# verify otherwise. WEBAUTHN_ORIGIN is the full origin, e.g. https://bede.local.
# WEBAUTHN_RP_ID=
# WEBAUTHN_RP_NAME=Bede
# WEBAUTHN_ORIGIN=
# TOTP_ISSUER=Bede Homeschool

# postgresql+asyncpg://user:password@host/dbname?ssl=require
DATABASE_URL=postgresql+asyncpg://REPLACE_ME

CORS_ORIGINS=http://localhost:5173,http://localhost:80
DISABLE_API_DOCS=false
PRODUCTION=false

# Required once PRODUCTION=true — an offline-verifiable license certificate,
# no phone-home (verified against a public key embedded in
# core/licensing.py). Issued by the operator via scripts/issue_license.py;
# paste the printed LICENSE_KEY= line here as-is.
# LICENSE_KEY=
