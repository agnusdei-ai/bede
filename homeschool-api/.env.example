# Copy this to .env and fill in every REPLACE_ME before running.
# The root .env.example has full documentation — this file is for running
# the API server standalone (outside Docker).

ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Optional: Bede's spoken voice via a self-hosted Kokoro model (no cloud API,
# no key) instead of the browser's robotic default speechSynthesis. Leave
# unset (or leave the model files out of KOKORO_MODEL_DIR) to skip this
# entirely — the frontend falls back automatically. See docs/VOICE_SETUP.md.
# KOKORO_MODEL_DIR=./models/kokoro
# KOKORO_VOICE=bm_george

SECRET_KEY=generate-with-openssl-rand-hex-32
MASTER_SECRET=generate-with-openssl-rand-hex-32

PARENT_PASSWORD=REPLACE_ME
# 6+ digits, no digit repeated (e.g. 384756, not 111111 or 123123)
CHILD_PIN=REPLACE_ME

# Optional: only for a dedicated PUBLIC DEMO deployment, never a family's real
# instance. Leave blank to disable the demo login entirely (default). If set,
# must differ from both PARENT_PASSWORD and CHILD_PIN — startup fails otherwise.
# Demo tokens expire in 15 minutes and can only reach a fixed, read-mostly
# tutoring session (services/ai_service.py + core/deps.py's require_real_user) —
# no pod/voice/admin/transcript access, no configuration rights.
# DEMO_PIN=
# DEMO_TOKEN_EXPIRE_MINUTES=15
# DEMO_STUDENT_NAME=Guest
# DEMO_GRADE=4
# DEMO_GRADE_STAGE=3-5

# Optional: parent-side MFA (FIDO2 security key like a YubiKey, and/or a TOTP
# authenticator app) on top of PARENT_PASSWORD. Leave WEBAUTHN_RP_ID blank to
# disable security-key support (default) — TOTP has no such requirement and
# is always available once a parent enrolls it from the setup screen.
# WEBAUTHN_RP_ID must be the exact domain (no scheme/port) tablets/browsers
# use to reach this deployment, e.g. bede.local — WebAuthn will refuse to
# verify otherwise. WEBAUTHN_ORIGIN is the full origin, e.g. https://bede.local.
# WEBAUTHN_RP_ID=
# WEBAUTHN_RP_NAME=Bede
# WEBAUTHN_ORIGIN=
# TOTP_ISSUER=Bede Homeschool

# postgresql+asyncpg://user:password@host/dbname?ssl=require
DATABASE_URL=postgresql+asyncpg://REPLACE_ME

CORS_ORIGINS=http://localhost:5173,http://localhost:80
DISABLE_API_DOCS=false
PRODUCTION=false
