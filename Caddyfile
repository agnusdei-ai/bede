{
  # LAN deployment — use Caddy's built-in CA instead of ACME/Let's Encrypt.
  # Run "make caddy-trust" to export the root cert and install it on tablets.
  local_certs
  admin off
}

# HTTPS: TLS-terminate and proxy to nginx
:443 {
  # No hostname in this site address on purpose — tablets connect via
  # whatever LAN IP the host machine has, which varies per household and
  # isn't known at config time. Without a hostname, Caddy has nothing to
  # pre-provision a cert for at startup, so it must issue one on demand
  # for whatever SNI shows up. `on_demand` here (not the global
  # on_demand_tls option) is what actually turns that on for this site;
  # it's safe without an `ask` endpoint because the internal CA has no
  # external abuse/rate-limit exposure. Without this, every handshake
  # fails with a TLS "internal error" alert — caught by
  # production-regression.yml's first real end-to-end boot, where every
  # container was demonstrably healthy yet https://localhost never
  # completed a handshake.
  tls internal {
    on_demand
  }

  reverse_proxy ui:80 {
    header_up Host              {host}
    header_up X-Real-IP         {remote_host}
    header_up X-Forwarded-For   {remote_host}
    header_up X-Forwarded-Proto https
  }
}

# HTTP → HTTPS redirect (tablets and browsers follow automatically) — except
# /trust, the "add a tablet" onboarding page. That one is deliberately left
# on plain HTTP: a brand-new device hasn't installed this server's
# certificate yet, so redirecting it to HTTPS first would hit the exact
# untrusted-cert warning this page exists to help them past. handle_path
# strips the /trust prefix before forwarding, so the trust service itself
# only ever sees "/", "/qr.svg", "/root-ca.crt".
:80 {
  handle_path /trust* {
    reverse_proxy trust:8080 {
      header_up Host {host}
    }
  }
  handle {
    redir https://{host}{uri} permanent
  }
}
